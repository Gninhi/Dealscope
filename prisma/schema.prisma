generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  createdAt DateTime @default(now())
  users     User[]
  icpProfiles   ICPProfile[]
  targetCompanies TargetCompany[]
  scanHistories  ScanHistory[]
  chatMessages   ChatMessage[]
  newsArticles   NewsArticle[]
  newsAlerts     NewsAlert[]
  newsBookmarks  NewsBookmark[]
}

model User {
  id            String    @id @default(cuid())
  workspaceId   String
  email         String    @unique
  password      String    @default("")
  emailVerified Boolean   @default(false)
  firstName     String    @default("")
  lastName      String    @default("")
  role            String    @default("member")
  resetToken      String?
  resetTokenExpiry DateTime?
  createdAt       DateTime  @default(now())
  workspace       Workspace @relation(fields: [workspaceId], references: [id])
}

model AppSetting {
  id            String   @id @default("app")
  isFirstSetup  Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ICPProfile {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  criteria    String   @default("{}")
  weights     String   @default("{}")
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  targetCompanies TargetCompany[]
}

model TargetCompany {
  id                String    @id @default(cuid())
  workspaceId       String
  icpProfileId      String?
  siren             String    @unique
  name              String
  legalName         String    @default("")
  sector            String    @default("")
  sizeRange         String    @default("")
  revenue           Float?
  address           String    @default("")
  city              String    @default("")
  postalCode        String    @default("")
  region            String    @default("")
  latitude          Float?
  longitude         Float?
  nafCode           String    @default("")
  employeeCount     Int?
  icpScore          Float?
  status            String    @default("a_contacter")
  notes             String    @default("")
  source            String    @default("manual")
  natureJuridique   String    @default("")
  categorieEntreprise String  @default("")
  // Champs enrichis depuis API Gouv + InfoGreffe
  nafLabel           String    @default("")
  dateImmatriculation String   @default("")
  statutEntreprise   String    @default("")
  greffe             String    @default("")
  trancheCA          String    @default("")
  dateClotureExercice String   @default("")
  adresseComplete    String    @default("")
  enrichedData       String    @default("{}")
  isEnriched         Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  workspace         Workspace @relation(fields: [workspaceId], references: [id])
  icpProfile        ICPProfile? @relation(fields: [icpProfileId], references: [id])
  signals           CompanySignal[]
  contacts          Contact[]
  pipelineStages    PipelineStage[]
  newsAlerts     NewsAlert[]

  @@index([workspaceId, status])
  @@index([workspaceId, sector])
  @@index([workspaceId, createdAt])
  @@index([workspaceId, updatedAt])
}

model CompanySignal {
  id          String   @id @default(cuid())
  companyId   String
  type        String
  title       String
  description String   @default("")
  source      String   @default("")
  detectedAt  DateTime @default(now())
  confidence  Float?
  company     TargetCompany @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model Contact {
  id            String   @id @default(cuid())
  companyId     String
  firstName     String   @default("")
  lastName      String   @default("")
  email         String   @default("")
  role          String   @default("")
  seniority     String   @default("")
  emailVerified Boolean  @default(false)
  company       TargetCompany @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model PipelineStage {
  id         String   @id @default(cuid())
  companyId  String
  stage      String
  assignedTo String   @default("")
  notes      String   @default("")
  movedAt    DateTime @default(now())
  company    TargetCompany @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([companyId, stage])
}

model ScanHistory {
  id              String    @id @default(cuid())
  workspaceId     String
  icpProfileId    String?
  status          String    @default("pending")
  totalTargets    Int       @default(0)
  processedTargets Int      @default(0)
  startedAt       DateTime  @default(now())
  completedAt     DateTime?
  workspace       Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

model ChatMessage {
  id          String   @id @default(cuid())
  workspaceId String
  role        String
  content     String
  createdAt   DateTime @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId, createdAt])
}

model NewsArticle {
  id          String   @id @default(cuid())
  workspaceId String
  title       String
  snippet     String   @default("")
  url         String   @unique
  hostName    String   @default("")
  favicon     String   @default("")
  date        String   @default("")
  category    String   @default("")
  query       String   @default("")
  source      String   @default("")
  isRead      Boolean  @default(false)
  isImportant Boolean  @default(false)
  createdAt   DateTime @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  bookmarks   NewsBookmark[]

  @@index([workspaceId, category])
}

model NewsAlert {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  type        String   @default("keyword")  // keyword, sector, company
  keywords    String   @default("[]")         // JSON array of keywords
  sector      String   @default("")
  companyId   String?
  company     TargetCompany? @relation(fields: [companyId], references: [id])
  isActive    Boolean  @default(true)
  lastTriggered DateTime?
  createdAt   DateTime @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])

  @@index([workspaceId])
}

model NewsBookmark {
  id          String   @id @default(cuid())
  workspaceId String
  articleId   String
  notes       String   @default("")
  createdAt   DateTime @default(now())
  workspace   Workspace @relation(fields: [workspaceId], references: [id])
  article     NewsArticle @relation(fields: [articleId], references: [id])

  @@index([workspaceId])
  @@index([workspaceId, articleId])
}
